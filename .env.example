# ─────────────────────────────────────────────────────────────
# 논사원 AI — 환경 변수 (P0)
# 이 파일을 복사해 .env 로 만들고 값을 채우세요:  cp .env.example .env
# .env 는 git에 커밋되지 않습니다(.gitignore).
# ─────────────────────────────────────────────────────────────

# [필수] PostgreSQL 연결 문자열 (Supabase Postgres)
# Supabase 대시보드 > Project Settings > Database > Connection string 에서 복사.
# 표준 PostgreSQL 연결이므로 추후 다른 Postgres로 이전해도 코드 변경 불필요.
#
#  - 앱/마이그레이션 모두 이 한 줄을 사용합니다.
#  - 직접 연결(5432) 또는 풀러(6543, transaction)를 모두 지원합니다.
#    (드라이버는 prepare=false 로 동작하므로 풀러도 안전합니다.)
#  - 비밀번호에 특수문자가 있으면 URL 인코딩하세요.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# [로그인 필수] Supabase Auth — 직원 로그인/로그아웃/비밀번호 재설정/계정 생성.
# Supabase 대시보드 > Project Settings > API 에서 복사.
#  - NEXT_PUBLIC_SUPABASE_URL      : Project URL (https://<ref>.supabase.co)
#  - NEXT_PUBLIC_SUPABASE_ANON_KEY : anon public 키. 미설정이면 모든 화면이 /login 으로 막힘.
#  - SUPABASE_SERVICE_ROLE_KEY     : service_role 키. 직원관리의 '로그인 계정 생성'에만 사용(서버 전용·노출 금지).
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 채팅로그 업로드 시 '논스톱서비스(직원)' 계정으로 분류할 user_name 목록(쉼표 구분).
# 이 목록에 포함되거나 이름에 '논스톱'이 들어가면 sender_type='staff' 로 저장됩니다.
NONSTOP_STAFF_NAMES=논스톱서비스

# [상담 데이터 구조화] Anthropic API — 대화에서 8개 항목 자동 추출(강제 tool use).
# https://console.anthropic.com 에서 발급.
ANTHROPIC_API_KEY=
# 추출 모델(저비용 분류용 Haiku 4.5 기본). 정확도가 더 필요하면 claude-sonnet-4-6 등으로 변경.
ANTHROPIC_EXTRACT_MODEL=claude-haiku-4-5
# OCR(이미지/PDF) 모델 — Claude 비전 재사용. 기본 Haiku 4.5(PDF가 안 되면 claude-sonnet-4-6).
ANTHROPIC_OCR_MODEL=claude-haiku-4-5

# [상담자료 음성 STT] OpenAI Whisper — WAV/MP3/M4A 음성을 텍스트로 변환.
#   키가 없으면 오디오 업로드는 원본만 보관되고 상태가 '변환실패'로 기록됩니다(교체 가능 어댑터 구조).
#   https://platform.openai.com/api-keys 에서 발급.
OPENAI_API_KEY=
OPENAI_STT_MODEL=whisper-1
